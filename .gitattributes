# Auto-detect text files and normalize line endings
* text=auto

# Force Unix LF for source files
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env   text eol=lf
*.ino   text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.mp4   binary
*.webp  binary
*.glb   binary
*.vrm   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.wav   binary
*.mp3   binary
